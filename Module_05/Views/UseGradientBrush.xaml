<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Module_05.Views.UseGradientBrush"
             Title="UseGradientBrush">
    <VerticalStackLayout>
        <Label Text="Gradient" FontSize="24" />
        <Grid RowDefinitions="150,150" ColumnDefinitions="1*, 1*">
            <VerticalStackLayout>
                <Border HeightRequest="120" Stroke="Blue" Padding="10" StrokeThickness="3">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="Red" Offset="0.0"></GradientStop>
                            <GradientStop Color="Orange" Offset="0.25"></GradientStop>
                            <GradientStop Color="Yellow" Offset="0.5"></GradientStop>
                            <GradientStop Color="Green" Offset="0.75"></GradientStop>
                            <GradientStop Color="Blue" Offset="1.0"></GradientStop>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1"></VerticalStackLayout>
            <VerticalStackLayout Grid.Row="1"></VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Grid.Row="1"></VerticalStackLayout>
        </Grid>
    </VerticalStackLayout>
</ContentPage>