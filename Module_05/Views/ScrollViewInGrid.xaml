<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Module_05.Views.ScrollViewInGrid"
             Title="ScrollViewInGrid">
    <Grid RowDefinitions="80, *, 40" Background="LightYellow">
        <Label Text="Beautiful Pictures" FontSize="32" FontFamily="ROR" VerticalOptions="Center" HorizontalOptions="Center" />
        <ScrollView BackgroundColor="GreenYellow" Grid.Row="1">
            <VerticalStackLayout>
                <Image Source="to_bali_cycle_path_1.jpg"></Image>
                <Image Source="to_bali_cycle_path_2.jpg"></Image>
                <Image Source="to_bali_cycle_path_3.jpg"></Image>
            </VerticalStackLayout>
        </ScrollView>
        <Label Text="The end of the journey" FontSize="14" FontFamily="SerifBk" Grid.Row="2" VerticalOptions="Center" HorizontalOptions="Center" />
    </Grid>
</ContentPage>