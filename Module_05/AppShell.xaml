<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Module_05.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Module_05"
    xmlns:views="clr-namespace:Module_05.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="Module_05">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    
    <ShellContent
        Title="BoxViewAndImage"
        ContentTemplate="{DataTemplate views:BoxViewAndImage}"
        Route="BoxViewAndImage" />

    <ShellContent
        Title="ScrollViewInGrid"
        ContentTemplate="{DataTemplate views:ScrollViewInGrid}"
        Route="ScrollViewInGrid" />
    
    <ShellContent
        Title="UseBorder"
        ContentTemplate="{DataTemplate views:UseBorder}"
        Route="UseBorder" />
    
    <ShellContent
        Title="UseBorderWithLineJoin"
        ContentTemplate="{DataTemplate views:UseBorderWithLineJoin}"
        Route="UseBorderWithLineJoin" />

</Shell>
