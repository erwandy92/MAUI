<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Module_07.Views.BindWithControl"
             Title="BindWithControl">
    <VerticalStackLayout>
        <BoxView Color="Red" 
                 Margin="20" 
                 BackgroundColor="Transparent"
                 WidthRequest="{Binding Source={x:Reference widthSlider}, Path=Value }" 
                 HeightRequest="50" 
                 CornerRadius="{Binding Source={x:Reference srcStepper}, Path=Value }">
        </BoxView>
        <HorizontalStackLayout HorizontalOptions="Center">
            <Label Text="{Binding Source={x:Reference srcStepper}, Path=Value, StringFormat='Corner Radius: {0}' }" Margin="15" />
            <Stepper x:Name="srcStepper" Minimum="0" Maximum="30" Increment="5"></Stepper>
        </HorizontalStackLayout>
        <HorizontalStackLayout HorizontalOptions="Center">
            <Slider x:Name="widthSlider" Minimum="50" Maximum="200" WidthRequest="200" Value="50"></Slider>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>