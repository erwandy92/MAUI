<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Module_07.Views.BindingMode"
             Title="BindingMode">
    <VerticalStackLayout>
        <Label x:Name="label" Margin="10"
            Text="{ Binding Source={x:Reference srcEntry}, Path='Text', StringFormat='Targer:{0}' }" />
        
        <HorizontalStackLayout>
            <Label Text="Source: " Margin="10,10,0,0"></Label>
            <Entry x:Name="srcEntry" MaxLength="30" ClearButtonVisibility="WhileEditing"></Entry>
        </HorizontalStackLayout>

        <!-- Two Way -->
        <HorizontalStackLayout>
            <Label Text="TwoWay Target: " Margin="10,10,0,0"></Label>
            <Entry x:Name="tgEntry" MaxLength="30" ClearButtonVisibility="WhileEditing"></Entry>
        </HorizontalStackLayout>

        <!-- One Way -->
        <HorizontalStackLayout>
            <Label Text="OneWay Target: " Margin="10,10,0,0"></Label>
            <Entry Text="{Binding Source={x:Reference srcEntry}, Path='Text', Mode=OneWay}"></Entry>
        </HorizontalStackLayout>

        <!-- One Way To Source -->
        <HorizontalStackLayout>
            <Label Text="OneWay Target To Source: " Margin="10,10,0,0"></Label>
            <Entry MaxLength="30" ClearButtonVisibility="WhileEditing">
                <Entry.Text>
                    <Binding Path="Text" Mode="OneWayToSource">
                        <Binding.Source>
                            <x:Reference>srcEntry</x:Reference>
                        </Binding.Source>
                    </Binding>
                </Entry.Text>
            </Entry>
        </HorizontalStackLayout>

        <!-- One Time -->
        <HorizontalStackLayout>
            <Label Text="OneTime Target: " Margin="10,10,0,0"></Label>
            <Entry x:Name="tgOneTime"></Entry>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>