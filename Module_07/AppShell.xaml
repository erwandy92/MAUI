<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Module_07.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Module_07"
    xmlns:views="clr-namespace:Module_07.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="Module_07">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    
    <ShellContent
        Title="Bind With Control"
        ContentTemplate="{DataTemplate views:BindWithControl}"
        Route="BindWithControl" />
    
    <ShellContent
        Title="Binding Mode"
        ContentTemplate="{DataTemplate views:BindingMode}"
        Route="BindingMode" />

</Shell>
