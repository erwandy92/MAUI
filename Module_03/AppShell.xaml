<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Module_03.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Module_03"
    xmlns:Pages="clr-namespace:Module_03.Pages"
    Shell.FlyoutBehavior="Disabled"
    Title="Module_03">
    
    <!-- To disable the TabBar on the multiple flyout display mode -->
    <!--Shell.TabBarIsVisible="False"-->

    <TabBar Route="Root">
        <ShellContent
            Title="Home"
            Icon="home.png"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />

        <ShellContent
            Title="Shop"
            Icon="shoping.png"
            ContentTemplate="{DataTemplate Pages:ShopPage}"
            Route="ShopPage" />

        <Tab Title="Setting" Icon="settings.png">
            <ShellContent
                Title="Profile"
                Icon="user.png"
                ContentTemplate="{DataTemplate Pages:ProfilePage}"
                Route="ProfilePage" />

            <ShellContent
                Title="Setting"
                Icon="settings.png"
                ContentTemplate="{DataTemplate Pages:SettingPage}"
                Route="SettingPage" />
        </Tab>
    </TabBar>
