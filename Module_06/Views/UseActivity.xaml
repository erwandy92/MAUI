        <ActivityIndicator IsRunning="True" Color="Green" WidthRequest="50" HeightRequest="50"></ActivityIndicator>
        <ProgressBar Progress="0.5" ProgressColor="Gold"></ProgressBar>
    </VerticalStackLayout>
</ContentPage>