<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="Module_02.MainPage"
             Title=".NET MAUI vs XAML">

    <ContentPage.Resources>
        <x:String x:Key="SubTitle">System Information:</x:String>
        
        <!-- Font Size -->
        <x:Double x:Key="H1">32</x:Double>
        <x:Double x:Key="Normal">20</x:Double>
        <x:Double x:Key="Small">18</x:Double>
        
        <!-- Color -->
        <Color x:Key="ForeColor">DarkBlue</Color>
        <Color x:Key="BackColor">#f8f8f8</Color>
    </ContentPage.Resources>

    <StackLayout BackgroundColor="{x:StaticResource BackColor}" Padding="20">
        <Label FontSize="{x:StaticResource H1}" Text="{x:StaticResource SubTitle}" TextColor="{x:StaticResource ForeColor}"></Label>
        <Label FontSize="{x:StaticResource Normal}" Text="{x:Static sys:Environment.MachineName}"></Label>
        <Label FontSize="{x:StaticResource Normal}">
            <Label.Text>
                <x:Static Member="sys:Environment.UserName"></x:Static>
            </Label.Text>
        </Label>
        <Button FontSize="{x:StaticResource Normal}" Text="Get OS Version" Clicked="btn_GetOSVersion"></Button>
        <Label x:Name="lblOSVersion" FontSize="{x:StaticResource Normal}"></Label>
        
        <!-- To show the phone type -->
        <Label FontSize="{x:StaticResource Small}" Text="{ OnPlatform WinUI='Windows', Android='Android', iOS='iOS'  }"></Label>
        <Label FontSize="{x:StaticResource Small}">
            <Label.Text>
                <OnIdiom x:TypeArguments="x:String"
                         Desktop="Desktop"
                         Tablet="Tablet"
                         Phone="Phone">
                </OnIdiom>
            </Label.Text>
        </Label>
    </StackLayout>

</ContentPage>
