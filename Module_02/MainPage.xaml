<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="Module_02.MainPage"
             Title=".NET MAUI vs XAML">

    <ContentPage.Resources>
        <x:String x:Key="SubTitle">System Information:</x:String>
    </ContentPage.Resources>

    <StackLayout>
        <Label FontSize="28" Text="{x:StaticResource SubTitle}"></Label>
        <Label FontSize="24" Text="{x:Static Member=sys:Environment.MachineName}"></Label>
        <Label FontSize="24">
            <Label.Text>
                <x:Static Member="sys:Environment.UserName"></x:Static>
            </Label.Text>
        </Label>
        <Button FontSize="20" Text="Get OS Version" Clicked="btn_GetOSVersion"></Button>
        <Label x:Name="lblOSVersion" FontSize="20"></Label>
        
        <!-- To show the phone type -->
        <Label FontSize="20" Text="{ OnPlatform WinUI='Windows', Android='Android', iOS='iOS'  }"></Label>
        <Label FontSize="20">
            <Label.Text>
                <OnIdiom x:TypeArguments="x:String"
                         Desktop="Desktop"
                         Tablet="Tablet"
                         Phone="Phone">
                </OnIdiom>
            </Label.Text>
        </Label>
    </StackLayout>

</ContentPage>
