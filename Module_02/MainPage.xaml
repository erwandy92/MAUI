<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="Module_02.MainPage"
             Title=".NET MAUI vs XAML">

    <ContentPage.Resources>
        <x:String x:Key="SubTitle">System Information:</x:String>
        
        <!-- Font Size -->
        <x:Double x:Key="H1">30</x:Double>
        <x:Double x:Key="Normal">20</x:Double>
        <x:Double x:Key="Small">18</x:Double>
        
        <!-- Padding -->
        <x:Double x:Key="PaddingLg">20</x:Double>
        <x:Double x:Key="PaddingSm">10</x:Double>
        
        <!-- Color -->
        <Color x:Key="ForeColor">DarkBlue</Color>
        <Color x:Key="BackColor">LightBlue</Color>
        <Color x:Key="SoftBackColor">#f8f8f8</Color>
        
        <!-- Set up style for specific type -->
        <Style TargetType="Label">
            <Setter Property="TextColor" Value="{x:StaticResource ForeColor}"></Setter>
            <Setter Property="FontSize" Value="{x:StaticResource Normal}"></Setter>
        </Style>

        <Style x:Key="Header" TargetType="Label"><!-- Specific type with key -->
            <Setter Property="Background" Value="{x:StaticResource BackColor}"></Setter>
            <Setter Property="TextColor" Value="{x:StaticResource ForeColor}"></Setter>
            <Setter Property="FontSize" Value="{x:StaticResource H1}"></Setter>
            <Setter Property="Padding" Value="{x:StaticResource PaddingSm}"></Setter>
        </Style>
    </ContentPage.Resources>

    <StackLayout BackgroundColor="{x:StaticResource SoftBackColor}" Padding="{x:StaticResource PaddingLg}">
        <Label Text="{x:StaticResource SubTitle}" Style="{StaticResource Header}"></Label>
        <Label Text="{x:Static sys:Environment.MachineName}"></Label>
        <Label>
            <Label.Text>
                <x:Static Member="sys:Environment.UserName"></x:Static>
            </Label.Text>
        </Label>
        <Button Text="Get OS Version" Clicked="btn_GetOSVersion"></Button>
        <Label x:Name="lblOSVersion"></Label>
        
        <!-- To show the phone type -->
        <Label Text="{ OnPlatform WinUI='Windows', Android='Android', iOS='iOS'  }"></Label>
        <Label>
            <Label.Text>
                <OnIdiom x:TypeArguments="x:String"
                         Desktop="Desktop"
                         Tablet="Tablet"
                         Phone="Phone">
                </OnIdiom>
            </Label.Text>
        </Label>
    </StackLayout>

</ContentPage>
