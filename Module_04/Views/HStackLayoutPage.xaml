<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Module_04.Views.HStackLayoutPage"
             Title="HStackLayoutPage">
    <HorizontalStackLayout Padding="8" Spacing="6">
        <Label  Text="StartI!" BackgroundColor="Red" VerticalOptions="Start" />
        <Label  Text="EndI!" BackgroundColor="Orange" VerticalOptions="End" />
        <Label  Text="CenterI!" BackgroundColor="Yellow" VerticalOptions="Center"  />
        <Label  Text="FillI!" BackgroundColor="Green" VerticalOptions="Fill" />

        <!-- Row 1 -->
        <Label Text="Pizza" BackgroundColor="#FFB3BA"  TextColor="#222" />
        <!-- Row 2 -->
        <Label Text="Sushi" BackgroundColor="#FFDFBA"  TextColor="#222" />
        <!-- Row 3 -->
        <Label Text="Burger" BackgroundColor="#FFFFBA"  TextColor="#222" />
    </HorizontalStackLayout>
</ContentPage>