<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Module_04.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Module_04"
    xmlns:views="clr-namespace:Module_04.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="Module_04">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="StackLayoutPage"
        ContentTemplate="{DataTemplate views:StackLayoutPage}"
        Route="StackLayoutPage" />
        
    <ShellContent
        Title="HStackLayoutPage"
        ContentTemplate="{DataTemplate views:HStackLayoutPage}"
        Route="HStackLayoutPage" />

    <ShellContent
        Title="VStackLayoutPage"
        ContentTemplate="{DataTemplate views:VStackLayoutPage}"
        Route="VStackLayoutPage" />

</Shell>
